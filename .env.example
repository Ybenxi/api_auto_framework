# 环境配置模板
# 复制此文件为 .env 并填写实际配置

# 环境标识 (dev/test/uat/prod)
ENV=dev

# API 基础 URL
BASE_URL=https://api-dev.accelerationcloud.info

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=dev_user
DB_PASSWORD=your_password
DB_NAME=dev_db

# 认证配置（如需覆盖默认值）
# TENANT_ID=your_tenant_id
# USER_ID=your_user_id
# BASIC_AUTH=your_basic_auth_token

# Core 配置（默认为 actc）
# CORE=actc
